@model IEnumerable<GPMS.Models.Role>

@{
    ViewData["Title"] = "Roles";
}

<link rel="stylesheet" href="~/css/site.css" />

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">
        <h2 class="page-title">ROLES</h2>

        <a asp-action="Create" class="btn">
            + New Role
        </a>
    </div>

    <!-- 🔥 LIVE SEARCH (no form) -->
    <div class="search-bar">

        <input type="text"
               id="roleSearch"
               class="form-control"
               placeholder="Search roles..." />

    </div>

    <!-- GRID -->
    @if (Model != null && Model.Any())
    {
        <div class="cards-grid" id="roleGrid">

            @foreach (var role in Model)
            {
                <div class="card role">
                    <div class="card-content">

                        <!-- TOP -->
                        <div class="card-top">
                            <h4 class="role-name">@role.RoleName</h4>
                        </div>

                    </div>

                    <!-- DESCRIPTION -->
                    <p>
                        @(string.IsNullOrEmpty(role.RoleDescription)
                            ? "No description available"
                            : role.RoleDescription)
                    </p>

                    <!-- META -->
                    <div class="card-meta">
                        <span>🔐 @role.RolePermissions.Count() permissions</span>
                    </div>

                    <hr />

                    <!-- ACTIONS -->
                    <div class="card-actions">

                        <a asp-action="Details"
                               asp-route-id="@role.RoleId"
                               class="btn">
                            View
                        </a>

                        <a asp-action="Edit"
                               asp-route-id="@role.RoleId"
                               class="btn">
                            Edit
                        </a>

                        <form asp-action="Delete"
                              asp-route-id="@role.RoleId"
                              method="post">

                            @Html.AntiForgeryToken()

                            <button type="submit"
                                    class="btn btn-delete"
                                    onclick="return confirm('Delete this role?')">
                                Delete
                            </button>

                        </form>

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <!-- EMPTY STATE -->
        <div class="no-data" id="noRoleMessage">
            <p>No roles found.</p>
        </div>
    }

</div>

<!-- 🔥 LIVE SEARCH SCRIPT -->
<script>

    function filterRoles() {

        let input = document.getElementById("roleSearch").value.toLowerCase();
        let cards = document.querySelectorAll(".card.role");
        let found = false;

        cards.forEach(card => {

            let name = card.querySelector(".role-name").innerText.toLowerCase();

            if (name.includes(input)) {
                card.style.display = "block";
                found = true;
            } else {
                card.style.display = "none";
            }

        });

        let noData = document.getElementById("noRoleMessage");
        if (noData) {
            noData.style.display = found ? "none" : "block";
        }

    }

    // 🔥 LIVE typing
    document.getElementById("roleSearch").addEventListener("keyup", filterRoles);

</script>