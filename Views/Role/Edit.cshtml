@model GPMS.ViewModels.RoleCreateViewModel

@{
    ViewData["Title"] = "Edit Role";
}

<div class="page-container">

    <div class="form-card">

        <h2 class="page-title">Edit Role</h2>

        <form asp-action="Edit" method="post">

            @Html.AntiForgeryToken()

            <!-- IMPORTANT: ROLE ID -->
            <input type="hidden" name="id" value="@Context.Request.RouteValues["id"]" />

            <!-- ROLE NAME -->
            <div class="form-group">
                <label>Role Name</label>
                <input asp-for="RoleName" class="form-control" />
                <span asp-validation-for="RoleName" class="text-danger"></span>
            </div>

            <!-- DESCRIPTION -->
            <div class="form-group">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- PERMISSIONS -->
            <div class="form-group">
                <label>PERMISSIONS</label>

                <div class="checkbox-list">
                    @for (int i = 0; i < Model.Permissions.Count; i++)
                    {
                        <div class="checkbox-item">

                            <input type="checkbox"
                                   asp-for="Permissions[i].IsSelected" />

                            <input type="hidden" asp-for="Permissions[i].Id" />
                            <input type="hidden" asp-for="Permissions[i].PermissionName" />

                            <label>@Model.Permissions[i].PermissionName</label>

                        </div>
                    }
                </div>
            </div>

            <!-- BUTTON -->
            <button type="submit" class="btn-save">
                Save Changes
            </button>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}