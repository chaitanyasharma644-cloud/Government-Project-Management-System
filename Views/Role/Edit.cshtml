@model GPMS.ViewModels.RoleCreateViewModel

@{
    ViewData["Title"] = "Edit Role";
}

<div class="page-container">

    <div class="form-card">

        <!-- PAGE HEADER -->
        <div class="page-header">
            <h2 class="page-title">Edit Role</h2>
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            <!-- ROLE ID -->
            <input type="hidden" name="id" value="@Context.Request.RouteValues["id"]" />

            <!-- ROLE NAME -->
            <div class="form-group">
                <label>Role Name</label>
                <input asp-for="RoleName" class="form-control" placeholder="Enter role name" />
                <span asp-validation-for="RoleName" class="text-danger"></span>
            </div>

            <!-- DESCRIPTION -->
            <div class="form-group">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Enter role description"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- PERMISSIONS -->
            <div class="form-group">
                <label>Select Permissions</label>

                @if (Model.Permissions != null && Model.Permissions.Any())
                {
                    <div class="cards-grid">

                        @for (int i = 0; i < Model.Permissions.Count; i++)
                        {
                            <label class="card role permission-card">

                                <!-- HIDDEN -->
                                <input type="hidden" asp-for="Permissions[i].Id" />
                                <input type="hidden" asp-for="Permissions[i].PermissionName" />

                                <!-- CHECKBOX -->
                                <input type="checkbox"
                                       asp-for="Permissions[i].IsSelected"
                                       class="permission-checkbox" />

                                <!-- CONTENT -->
                                <div class="permission-content">
                                    <h4>@Model.Permissions[i].PermissionName</h4>
                                    <p class="permission-text">Grant access</p>
                                </div>

                            </label>
                        }

                    </div>
                }
                else
                {
                    <p class="no-data">No permissions available</p>
                }

            </div>

            <!-- BUTTON -->
            <div class="form-actions">
                <button type="submit" class="btn-save">
                    Save Changes
                </button>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}