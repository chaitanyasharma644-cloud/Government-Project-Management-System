@model GPMS.Models.Employee
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Edit Employee";
}

<link rel="stylesheet" href="~/css/site.css" />

<div class="page-container">

    <div class="form-card">

        <h2 class="page-title">Edit Employee</h2>

        <form asp-action="Edit" method="post">

            @Html.AntiForgeryToken()

            <!-- Hidden ID -->
            <input type="hidden" asp-for="EmployeeId" />

            <!-- Validation Summary -->
            <div asp-validation-summary="All" class="text-danger"></div>

            <!-- NAME -->
            <div class="form-group">
                <label asp-for="EmployeeName"></label>
                <input asp-for="EmployeeName"
                       class="form-control"
                       placeholder="Enter employee name..." />
                <span asp-validation-for="EmployeeName" class="text-danger"></span>
            </div>

            <!-- EMAIL -->
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email"
                       class="form-control"
                       placeholder="Enter email..." />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- USERNAME -->
            <div class="form-group">
                <label asp-for="Username"></label>
                <input asp-for="Username"
                       class="form-control"
                       placeholder="Enter username..." />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <!-- DESIGNATION (IMPORTANT) -->
            <div class="form-group">
                <label asp-for="DesignationId"></label>

                <select asp-for="DesignationId"
                        asp-items="@(new SelectList(ViewBag.Designations, "DesignationId", "DesignationName"))"
                        class="form-control">
                    <option value="">-- Select Designation --</option>
                </select>

                <span asp-validation-for="DesignationId" class="text-danger"></span>
            </div>

            <!-- ACTION BUTTON -->
            <div class="form-actions">
                <button type="submit" class="btn-save">
                    Save Changes
                </button>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}