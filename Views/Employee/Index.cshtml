@model IEnumerable<GPMS.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<link rel="stylesheet" href="~/css/site.css" />

<style>
    :root {
        --primary: #3b82f6;
    }

    /* SEARCH */
    .search-bar {
        margin-bottom: 15px;
    }

        .search-bar input {
            width: 1075px;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 6px;
        }

    /* TABLE */
    .employee-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 10px;
        overflow: hidden;
    }

        .employee-table thead {
            background-color: var(--primary);
            color: white;
        }

        .employee-table th {
            padding: 14px;
            text-align: left;
            font-weight: 500;
        }

        .employee-table td {
            padding: 14px;
        }

        .employee-table tbody tr {
            border-bottom: 1px solid #eee;
            transition: 0.2s;
        }

            .employee-table tbody tr:hover {
                background-color: #f5f7ff;
            }

    .actions a {
        margin-right: 6px;
    }

    .no-data {
        text-align: center;
        padding: 20px;
        color: #888;
    }
</style>

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">
        <h2 class="page-title">EMPLOYEES</h2>
        <a asp-action="Create" class="btn">+ Add Employee</a>
    </div>

    <!-- LIVE SEARCH -->
    <div class="search-bar">
        <input type="text" id="employeeSearch" placeholder="Search employee..." />
    </div>

    <!-- TABLE -->
    <table class="employee-table">
        <thead>
            <tr>
                <th>Employee Name</th>
                <th>Designation</th>
                <th>Email</th>
                <th>Username</th>
                <th style="width:170px;">Actions</th>
            </tr>
        </thead>

        <tbody id="employeeTableBody">
            @if (Model != null && Model.Any())
            {
                foreach (var emp in Model)
                {
                    <tr>
                        <td class="emp-name">@emp.EmployeeName</td>
                        <td>@emp.Designation?.DesignationName</td>
                        <td>@emp.Email</td>
                        <td>@emp.Username</td>

                        <td class="actions">
                            <a asp-action="Edit" asp-route-id="@emp.EmployeeId" class="btn">Edit</a>
                            <a asp-action="Delete" asp-route-id="@emp.EmployeeId" class="btn btn-delete">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr id="noDataRow">
                    <td colspan="5" class="no-data">No employees found</td>
                </tr>
            }
        </tbody>
    </table>

</div>

<!-- LIVE SEARCH SCRIPT -->
<script>

    function filterEmployees() {

        let input = document.getElementById("employeeSearch").value.toLowerCase();
        let rows = document.querySelectorAll("#employeeTableBody tr");

        rows.forEach(row => {

            let nameCell = row.querySelector(".emp-name");

            if (!nameCell) return;

            let name = nameCell.innerText.toLowerCase();

            row.style.display = name.includes(input) ? "" : "none";

        });

    }

    document.getElementById("employeeSearch").addEventListener("keyup", filterEmployees);

</script>