@model GPMS.Models.Employee

@{
    ViewData["Title"] = "Create Employee";
}

<div class="page-container">

    <div class="form-card">

        <h2 class="page-title">Add Employee</h2>

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger"></div>
            <!-- NAME -->
            <div class="form-group">
                <label>Name</label>
                <input asp-for="EmployeeName"
                       class="form-control"
                       placeholder="Enter employee name..." />
                <span asp-validation-for="EmployeeName" class="text-danger"></span>
            </div>

            <!-- EMAIL -->
            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email"
                       type="email"
                       class="form-control"
                       placeholder="Enter email..." />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- USERNAME -->
            <div class="form-group">
                <label>Username</label>
                <input asp-for="Username"
                       class="form-control"
                       placeholder="Enter username..." />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <!-- DESIGNATION -->
            <div class="form-group">
                <label>Select Designation</label>
                <select asp-for="DesignationId"
                        asp-items="ViewBag.DesignationList"
                        class="form-control">
                    <option value="">-- Select Designation --</option>
                </select>
                <span asp-validation-for="DesignationId" class="text-danger"></span>
            </div>

            <!-- INFO MESSAGE -->
            <div class="form-group">
                <small style="color: gray;">
                    Default Password: <b>nicemployee123#</b>
                </small>
            </div>

            <!-- BUTTON -->
            <button type="submit" class="btn-save">
                Add Employee
            </button>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}