@model List<Project>

@{
    ViewData["Title"] = "Projects";

    var canCreate = ViewBag.CanCreate == true;
    var permissions = ViewBag.ProjectPermissions as Dictionary<int, List<string>>;
}

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">
        <h2 class="page-title">PROJECTS</h2>

        @if (canCreate)
        {
            <a href="/Project/Create" class="btn">+ New Project</a>
        }
    </div>

    <!-- 🔥 FILTER BAR (UPDATED) -->
    <div class="search-bar project-search-bar">

        <!-- EXISTING SEARCH -->
        <input type="text"
               id="projectSearch"
               class="form-control"
               placeholder="Search projects..." />

        <!-- NEW FILTERS -->
        <input type="date" id="startDate" class="form-control" />
        <input type="date" id="endDate" class="form-control" />

        <select id="status" class="form-control">
            <option value="">All Status</option>
            <option value="Ongoing">Ongoing</option>
            <option value="Completed">Completed</option>
        </select>

        <!-- SEARCH -->
        <button class="btn btn-primary-custom" onclick="applyFilters()">Search</button>

        <!-- EXPORT -->
        <button class="btn btn-success" onclick="exportExcel()">Export</button>

    </div>

    <!-- NO DATA MESSAGE -->
    <div id="noProjectMessage" class="no-data" style="display:none;">
        No projects found.
    </div>

    <!-- PROJECT GRID -->
    <div class="cards-grid" id="projectGrid">

        @foreach (var p in Model)
        {
            var perms = permissions != null && permissions.ContainsKey(p.ProjectId)
                ? permissions[p.ProjectId]
                : new List<string>();

            bool canEdit = perms.Contains("EditProject");
            bool canDelete = perms.Contains("DeleteProject");

            <div class="card project">
                <div class="card-content">
                    <div class="card-top">
                        <h3 class="project-name">@p.ProjectName</h3>

                        <span class="status @(p.ProjectStatus == "Completed" ? "completed" : "ongoing")">
                            @(p.ProjectStatus ?? "—")
                        </span>
                    </div>
                </div>

                <div class="card-meta">
                    <span>🧩 @p.Modules.Count modules</span>
                    <span class="start-date" data-date="@p.ProjectStartDate.ToString("yyyy-MM-dd")">
                        📅 @p.ProjectStartDate.ToString("MMM dd, yyyy")
                    </span>
                    <span class="end-date" data-date="@(p.ProjectEndDate?.ToString("yyyy-MM-dd"))">
                        🏁 @(p.ProjectEndDate?.ToString("MMM dd, yyyy") ?? "N/A")
                    </span>
                </div>

                <hr />

                <div class="card-actions">

                    <a href="/Project/Details/@p.ProjectId" class="btn">View</a>

                    @if (canEdit)
                    {
                        <a href="/Project/Edit/@p.ProjectId" class="btn">Edit</a>
                    }

                    @if (canDelete)
                    {
                        <form method="post"
                              action="/Project/Delete/@p.ProjectId"
                              style="display:inline;"
                              onsubmit="return confirm('Delete project?')">

                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-delete">Delete</button>
                        </form>
                    }

                </div>

            </div>
        }

    </div>

</div>

<script>

    function applyFilters() {

        let search = document.getElementById("projectSearch").value.toLowerCase();
        let start = document.getElementById("startDate").value;
        let end = document.getElementById("endDate").value;
        let status = document.getElementById("status").value.toLowerCase();

        let cards = document.querySelectorAll(".card.project");
        let found = false;

        cards.forEach(card => {

            let name = card.querySelector(".project-name").innerText.toLowerCase();
            let projectStatus = card.querySelector(".status").innerText.toLowerCase();

            let startDate = card.querySelector(".start-date").dataset.date;
            let endDate = card.querySelector(".end-date").dataset.date;

            let match = true;

            // 🔍 NAME FILTER
            if (search && !name.includes(search))
                match = false;

            // 📌 STATUS FILTER
            if (status && projectStatus !== status)
                match = false;

            // 📅 START DATE FILTER
            if (start && startDate < start)
                match = false;

            // 📅 END DATE FILTER
            if (end && endDate && endDate > end)
                match = false;

            if (match) {
                card.style.display = "block";
                found = true;
            } else {
                card.style.display = "none";
            }

        });

        document.getElementById("noProjectMessage").style.display = found ? "none" : "block";
    }

    function exportExcel() {

        let start = document.getElementById("startDate").value;
        let end = document.getElementById("endDate").value;
        let status = document.getElementById("status").value;

        window.location.href = `/Project/ExportToExcel?startDate=${start}&endDate=${end}&status=${status}`;
    }

    document.getElementById("projectSearch").addEventListener("keyup", function (e) {
        applyFilters();

        if (e.key === "Enter") {
            applyFilters();
        }
    });

</script>