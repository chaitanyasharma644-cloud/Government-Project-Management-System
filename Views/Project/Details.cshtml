@model GPMS.Models.Project

@{
    ViewData["Title"] = "Project Details";

    var modulePermissions = ViewBag.ModulePermissions as Dictionary<int, List<string>>;
}

<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

<div class="page-container">

    <!-- 🔥 ALERTS -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- HEADER -->
    <div class="page-header">
        <h2>@Model.ProjectName</h2>

        <span class="status @(Model.ProjectStatus == "Completed" ? "completed" : "ongoing")">
            @(Model.ProjectStatus ?? "—")
        </span>
    </div>

    <!-- PROJECT INFO -->
    <p>@Model.ProjectDetails</p>

    <div class="card-meta">
        <span>📅 Start: @Model.ProjectStartDate.ToString("MMM dd, yyyy")</span>
        <span>🏁 End: @(Model.ProjectEndDate?.ToString("MMM dd, yyyy") ?? "N/A")</span>
    </div>

    <hr />

    <!-- MODULE HEADER -->
    <div class="page-header">
        <h3>Modules</h3>

        @if (ViewBag.CanCreateModule == true)
        {
            <a href="/Module/Create?projectId=@Model.ProjectId" class="btn">
                + Add Module
            </a>
        }
    </div>

    <!-- MODULE GRID -->
    <div class="cards-grid">

        @foreach (var m in Model.Modules)
        {
            var perms = modulePermissions != null && modulePermissions.ContainsKey(m.ModuleId)
                ? modulePermissions[m.ModuleId]
                : new List<string>();

            bool canView = perms.Contains("ViewModule");
            bool canEdit = perms.Contains("EditModule");
            bool canDelete = perms.Contains("DeleteModule");

            <div class="card module">

                <div class="card-top">
                    <h4>@m.ModuleName</h4>

                    <span class="status @(m.ModuleStatus == "Completed" ? "completed" : "ongoing")">
                        @(m.ModuleStatus ?? "—")
                    </span>
                </div>

                <div class="card-meta">
                    <span>📅 @m.ModuleStartDate?.ToString("MMM dd, yyyy")</span>
                    <span>🏁 @(m.ModuleEndDate?.ToString("MMM dd, yyyy") ?? "N/A")</span>
                    <span>🎯 @m.Tasks.Count tasks</span>
                </div>

                <hr />

                <!-- ACTIONS -->
                <div>

                    @if (canView)
                    {
                        <a href="/Module/Details/@m.ModuleId" class="btn">View</a>
                    }

                    @if (canEdit)
                    {
                        <a href="/Module/Edit/@m.ModuleId" class="btn">Edit</a>
                    }

                    @if (canDelete)
                    {
                        <form method="post"
                              action="/Module/Delete/@m.ModuleId"
                              style="display:inline;"
                              onsubmit="return confirm('Delete module? This requires deleting all tasks first.')">

                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-delete">Delete</button>
                        </form>
                    }

                </div>

            </div>
        }

    </div>

    <!-- ============================= -->
    <!-- ASSIGNED EMPLOYEES -->
    <!-- ============================= -->
    @if (ViewBag.CanViewEmployee == true)
    {
        <div class="assignment-container">

            <div class="assignment-header">
                <h3>Assigned Employees</h3>

                @if (ViewBag.CanEditEmployee == true)
                {
                    <a asp-controller="Assignment"
                           asp-action="AssignEmployee"
                           asp-route-id="@Model.ProjectId"
                           asp-route-type="project"
                           class="btn">
                        + Add Assignment
                    </a>
                }
            </div>

            <table class="assignment-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Email</th>
                        <th>Username</th>
                        <th>Assigned Date</th>

                        @if (ViewBag.CanEditEmployee == true)
                        {
                            <th>Actions</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Assignments != null && Model.Assignments.Any())
                    {
                        foreach (var item in Model.Assignments)
                        {
                            <tr>
                                <td>@item.Employee.EmployeeName</td>
                                <td>@(item.Role != null ? item.Role.RoleName : "Not assigned")</td>
                                <td>@item.Employee.Email</td>
                                <td>@item.Employee.Username</td>
                                <td>@item.AssignedDate.ToString("dd MMM yyyy")</td>

                                @if (ViewBag.CanEditEmployee == true)
                                {
                                    <td class="action-buttons">
                                        <a asp-controller="Assignment"
                                               asp-action="DeleteAssignment"
                                               asp-route-id="@item.AssignmentId"
                                               class="btn btn-delete">
                                            Remove
                                        </a>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="no-data">
                                No employees assigned
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    }

</div>