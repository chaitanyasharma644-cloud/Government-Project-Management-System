@model Project
@{
    ViewData["Title"] = "Edit Project";
}

<link rel="stylesheet" href="~/css/project-edit.css" />

<div class="edit-page">

    <div class="edit-card">

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="ProjectId" />

            <div class="form-group">

                <label>Project Name</label>

                <input asp-for="ProjectName" class="form-control" />

            </div>

            <div class="form-group">

                <label>Details</label>

                <textarea asp-for="ProjectDetails" class="form-control textarea"></textarea>

            </div>

            <div class="form-row">

                <div class="form-group">

                    <label>Status</label>

                    <select asp-for="ProjectStatus" class="form-control">

                        <option>Ongoing</option>
                        <option>Completed</option>

                    </select>

                </div>

                <div class="form-group">

                    <label>Start Date</label>

                    <input asp-for="ProjectStartDate"
                           type="date"
                           class="form-control" />

                </div>

            </div>

            <div class="form-group">

                <label>End Date</label>

                <input asp-for="ProjectEndDate"
                       type="date"
                       class="form-control" />

            </div>

            <button type="submit" class="btn-save">
                Save Changes
            </button>

        </form>

    </div>

</div>