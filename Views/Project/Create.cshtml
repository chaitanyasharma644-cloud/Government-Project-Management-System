@model GPMS.Models.Project

@{
    ViewData["Title"] = "Create Project";
}

<div class="page-container">

    <div class="form-card">

        <h2 class="page-title">Create Project</h2>

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <!-- PROJECT NAME -->
            <div class="form-group">
                <label>Project Name</label>
                <input asp-for="ProjectName" class="form-control" />
                <span asp-validation-for="ProjectName" class="text-danger"></span>
            </div>

            <!-- DETAILS -->
            <div class="form-group">
                <label>Details</label>
                <textarea asp-for="ProjectDetails" class="form-control"></textarea>
                <span asp-validation-for="ProjectDetails" class="text-danger"></span>
            </div>

            <!-- STATUS -->
            <div class="form-group">
                <label>Status</label>
                <select asp-for="ProjectStatus" class="form-control">
                    <option value="">-- Select --</option>
                    <option>Ongoing</option>
                    <option>Completed</option>
                </select>
                <span asp-validation-for="ProjectStatus" class="text-danger"></span>
            </div>

            <!-- DATES -->
            <div class="form-row">

                <div class="form-group">
                    <label>Start Date</label>
                    <input asp-for="ProjectStartDate" type="date" class="form-control" />
                    <span asp-validation-for="ProjectStartDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>End Date</label>
                    <input asp-for="ProjectEndDate" type="date" class="form-control" />
                    <span asp-validation-for="ProjectEndDate" class="text-danger"></span>
                </div>

            </div>

            <!-- BUTTON -->
            <button type="submit" class="btn-save">
                Create Project
            </button>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}