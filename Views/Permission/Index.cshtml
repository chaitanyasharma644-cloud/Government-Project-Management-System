@model IEnumerable<GPMS.Models.Permission>

@{
    ViewData["Title"] = "Permissions";
}

<link rel="stylesheet" href="~/css/site.css" />

<style>
    :root {
        --primary: #6366f1;
    }

    /* SEARCH */
    .search-bar {
        margin-bottom: 15px;
    }

        .search-bar input {
            width: 1075px;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 6px;
        }

    /* TABLE */
    .permission-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 10px;
        overflow: hidden;
    }

        .permission-table thead {
            background-color: var(--primary);
            color: white;
        }

        .permission-table th {
            padding: 14px;
            text-align: left;
            font-weight: 500;
        }

        .permission-table td {
            padding: 14px;
        }

        .permission-table tbody tr {
            border-bottom: 1px solid #eee;
            transition: 0.2s;
        }

            .permission-table tbody tr:hover {
                background-color: #f5f7ff;
            }

    .no-data {
        text-align: center;
        padding: 20px;
        color: #888;
    }
</style>

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">
        <h2 class="page-title">PERMISSIONS</h2>
    </div>

    <!-- 🔥 LIVE SEARCH -->
    <div class="search-bar">
        <input type="text" id="permissionSearch" placeholder="Search permission..." />
    </div>

    <!-- TABLE -->
    <table class="permission-table">
        <thead>
            <tr>
                <th>Permission Name</th>
                <th>Description</th>
            </tr>
        </thead>

        <tbody id="permissionTableBody">
            @if (Model != null && Model.Any())
            {
                foreach (var p in Model)
                {
                    <tr>
                        <td class="perm-name">@p.PermsName</td>
                        <td>@p.Description</td>
                    </tr>
                }
            }
            else
            {
                <tr id="noDataRow">
                    <td colspan="2" class="no-data">No permissions found</td>
                </tr>
            }
        </tbody>
    </table>

</div>

<!-- 🔥 LIVE SEARCH SCRIPT -->
<script>

    function filterPermissions() {

        let input = document.getElementById("permissionSearch").value.toLowerCase();
        let rows = document.querySelectorAll("#permissionTableBody tr");
        let found = false;

        rows.forEach(row => {

            let nameCell = row.querySelector(".perm-name");

            if (!nameCell) return; // skip no-data row

            let name = nameCell.innerText.toLowerCase();

            if (name.includes(input)) {
                row.style.display = "";
                found = true;
            } else {
                row.style.display = "none";
            }

        });

    }

    // 🔥 LIVE typing
    document.getElementById("permissionSearch").addEventListener("keyup", filterPermissions);

</script>