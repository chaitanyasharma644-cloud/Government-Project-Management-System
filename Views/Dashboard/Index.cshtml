@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="dashboard-container">
 <!-- STATS CARDS -->

    <div class="stats-grid">

        <div class="stat-card project">
            <div class="icon">📁</div>
            <div class="number">@ViewBag.Projects</div>
            <div class="label">PROJECTS</div>
        </div>

        <div class="stat-card employees">
            <div class="icon">👥</div>
            <div class="number">@ViewBag.Employees</div>
            <div class="label">EMPLOYEES</div>
        </div>

        <div class="stat-card ongoing">
            <div class="icon">▶</div>
            <div class="number">@ViewBag.Ongoing</div>
            <div class="label">ONGOING</div>
        </div>

        <div class="stat-card modules">
            <div class="icon">✔</div>
            <div class="number">@ViewBag.Completed</div>
            <div class="label">COMPLETED</div>
        </div>

    </div>
    <!-- QUICK ACTIONS -->

    <div class="panel quick-actions">

        <h3>Quick Actions</h3>

        <div class="actions">

            <button class="qa-project" onclick="location.href='/Project/Create'">
                + New Project
            </button>

            <button class="qa-module" onclick="location.href='/Module/Create'">+ New Module</button>

            <button class="qa-task" onclick="location.href='/Task/Create'">+ New Task</button>

            <button class="qa-employee">+ New Employee</button>

            <button class="qa-assignment">+ New Assignment</button>

            <button class="qa-designation">+ New Designation</button>

            <button class="qa-role" onclick="location.href='/Role/Create'">+ New Role</button>

            <button class="qa-permission">+ New Permission</button>

        </div>

    </div>

</div>
