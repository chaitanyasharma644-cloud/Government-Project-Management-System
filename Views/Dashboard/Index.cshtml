@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="dashboard-container">

    <!-- 🔥 TITLE -->
    <h2 class="mb-4">
        @(ViewBag.IsAdmin ? "Admin Dashboard" : "My Dashboard")
    </h2>

    <div class="stats-grid">

        <div class="stat-card project">
            <div class="icon">📁</div>
            <div class="number">@ViewBag.ProjectCount</div>
            <div class="label">PROJECTS</div>
        </div>

        @if (ViewBag.IsAdmin)
{
        <div class="stat-card employees">
            <div class="icon">👥</div>
            <div class="number">@ViewBag.EmployeeCount</div>
            <div class="label">EMPLOYEES</div>
        </div>
}

else
{
            <div class="stat-card modules">
                <div class="icon">📦</div>
                <div class="number">@ViewBag.ModuleCount</div>
                <div class="label">MODULES</div>
            </div>
}

        <div class="stat-card ongoing">
            <div class="icon">▶</div>
            <div class="number">@ViewBag.Ongoing</div>
            <div class="label">ONGOING</div>
        </div>

        <div class="stat-card modules">
            <div class="icon">✔</div>
            <div class="number">@ViewBag.Completed</div>
            <div class="label">COMPLETED</div>
        </div>

    </div>

    <!-- ========================= -->
    <!-- 👑 ADMIN DASHBOARD -->
    <!-- ========================= -->
    @if (ViewBag.IsAdmin == true)
    {

        <!-- 👑 ADMIN QUICK ACTIONS -->
        <div class="panel quick-actions">

            <h3>Quick Actions</h3>

            <div class="actions">

                <button class="qa-project" onclick="location.href='/Project/Create'">
                    + New Project
                </button>

                <button class="qa-module" onclick="location.href='/Module/Create'">
                    + New Module
                </button>

                <button class="qa-task" onclick="location.href='/Task/Create'">
                    + New Task
                </button>

                <button class="qa-employee" onclick="location.href='/Employee/Create'">
                    + New Employee
                </button>

                <button class="qa-designation" onclick="location.href='/Designation/Create'">
                    + New Designation
                </button>

                <button class="qa-role" onclick="location.href='/Role/Create'">
                    + New Role
                </button>

            </div>

        </div>
    }

</div>