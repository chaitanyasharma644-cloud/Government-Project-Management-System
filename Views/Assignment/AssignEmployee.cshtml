@model GPMS.ViewModels.AssignmentViewModel

@{
    ViewData["Title"] = "Assign Employee";

    var disableModule = Model.CurrentLevel == "project" ? "disabled" : "";
    var disableTask = Model.CurrentLevel != "task" ? "disabled" : "";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<div class="page-container">

    <div class="form-card">

        <div class="page-header">
            <h2 class="page-title">Assign Employee</h2>
        </div>

        <form asp-action="AssignEmployee" method="post">

            @Html.AntiForgeryToken()

            <!-- 🔒 HIDDEN -->
            <input type="hidden" asp-for="CurrentLevel" />

            <!-- EMPLOYEE -->
            <div class="form-group">
                <label>Select Employee</label>
                <select asp-for="EmployeeId"
                        asp-items="Model.Employees"
                        class="form-control"
                        id="employeeDropdown">
                    <option value="">-- Search & Select Employee --</option>
                </select>
                <span asp-validation-for="EmployeeId" class="text-danger"></span>
            </div>

            <!-- PROJECT -->
            <div class="form-group">
                <label>Select Project</label>
                <select asp-for="ProjectId"
                        asp-items="Model.Projects"
                        class="form-control"
                        id="projectDropdown">
                    <option value="">-- Select Project --</option>
                </select>
                <span asp-validation-for="ProjectId" class="text-danger"></span>
            </div>

            <!-- MODULE -->
            <div class="form-group">
                <label>Select Module</label>
                <select asp-for="ModuleId"
                        asp-items="Model.Modules"
                        class="form-control"
                        id="moduleDropdown"
                        >
                    <option value="">-- Select Module --</option>
                </select>
            </div>

            <!-- TASK -->
            <div class="form-group">
                <label>Select Task</label>
                <select asp-for="TaskId"
                        asp-items="Model.Tasks"
                        class="form-control"
                        id="taskDropdown"
                        >
                    <option value="">-- Select Task --</option>
                </select>
            </div>

            <!-- DATE -->
            <div class="form-group">
                <label>Assignment Date</label>
                <input asp-for="AssignedDate" type="date" class="form-control" />
                <span asp-validation-for="AssignedDate" class="text-danger"></span>
            </div>

            <!-- ROLE -->
            <div class="form-group">
                <label>Select Role</label>
                <select asp-for="RoleId"
                        asp-items="Model.Roles ?? new SelectList(Enumerable.Empty<SelectListItem>())"
                        class="form-control"
                        id="roleDropdown">
                    <option value="">-- Select Role --</option>
                </select>
                <span asp-validation-for="RoleId" class="text-danger"></span>
            </div>

            <!-- BUTTONS -->
            <div class="form-group text-center">
                <button type="submit" class="btn btn-primary">Assign</button>

                <a asp-controller="Project"
                   asp-action="Details"
                   asp-route-id="@Model.ProjectId"
                   class="btn btn-delete">
                    Cancel
                </a>
            </div>

        </form>

    </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
$(document).ready(function () {

    $('#employeeDropdown').select2({
        placeholder: "Search and select employee",
        allowClear: true,
        width: '100%'
    });

    const level = '@Model.CurrentLevel';

    if (level === "project") {
        $('#moduleDropdown').prop('disabled', true);
        $('#taskDropdown').prop('disabled', true);
    }

    if (level === "module") {
        $('#moduleDropdown').prop('disabled', false);
        $('#taskDropdown').prop('disabled', true);
    }

    if (level === "task") {
        $('#moduleDropdown').prop('disabled', false);
        $('#taskDropdown').prop('disabled', false);
    }

    $('#projectDropdown').change(function () {
        if ($(this).val()) {
            $('#moduleDropdown').prop('disabled', false);
        } else {
            $('#moduleDropdown').prop('disabled', true).val('');
            $('#taskDropdown').prop('disabled', true).val('');
        }
    });

    $('#moduleDropdown').change(function () {
        if ($(this).val()) {
            $('#taskDropdown').prop('disabled', false);
        } else {
            $('#taskDropdown').prop('disabled', true).val('');
        }
    });

});
</script>