@model GPMS.Models.Task
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

<div class="page-container">

    <div class="form-card">

        <!-- HEADER -->
        <div class="page-header">
            <div>
                <h2 class="page-title">@Model.TaskName</h2>
                <p class="text-muted">
                    @Model.Module?.ModuleName • @Model.Module?.Project?.ProjectName
                </p>
            </div>

            <span class="status @(Model.TaskStatus?.ToLower())">
                @Model.TaskStatus
            </span>
        </div>

        <!-- DESCRIPTION -->
        <div class="form-group">
            <label>Description</label>
            <p>@Model.TaskDescription</p>
        </div>

        <!-- GRID DETAILS -->
        <div class="form-row">

            <div class="form-group">
                <label>Project</label>
                <p>@Model.Module?.Project?.ProjectName</p>
            </div>

            <div class="form-group">
                <label>Module</label>
                <p>@Model.Module?.ModuleName</p>
            </div>

        </div>

        <div class="form-row">

            <div class="form-group">
                <label>Start Date</label>
                <p>@Model.TaskStartDate?.ToString("dd MMM yyyy")</p>
            </div>

            <div class="form-group">
                <label>End Date</label>
                <p>@Model.TaskEndDate?.ToString("dd MMM yyyy")</p>
            </div>

        </div>

        <!-- ACTIONS -->
        <div style="display:flex; justify-content:space-between; margin-top:20px;">

            <a asp-action="Index" class="btn">
                ← Back
            </a>

        </div>

    </div>

    <!-- ============================= -->
    <!-- ASSIGNED EMPLOYEES SECTION -->
    <!-- ============================= -->

    <div class="assignment-container">

        <div class="assignment-header">
            <h3>Assigned Employees</h3>

            <a asp-controller="Assignment"
                   asp-action="AssignEmployee"
                   asp-route-id="@Model.TaskId"
                   asp-route-type="module"
                   class="btn">
                + Add Assignment
            </a>
        </div>

        <table class="assignment-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Username</th>
                    <th>Assigned Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Assignments != null && Model.Assignments.Any())
                {
                    foreach (var item in Model.Assignments)
                    {
                        <tr>
                            <td>@item.Employee.EmployeeName</td>
                            <td>@item.Employee.Email</td>
                            <td>@item.Employee.Username</td>
                            <td>@item.AssignedDate.ToString("dd MMM yyyy")</td>

                            <td class="action-buttons">
                                <a asp-controller="Assignment"
                                       asp-action="EditAssignment"
                                       asp-route-id="@item.AssignmentId"
                                       class="btn-edit">
                                    Edit
                                </a>

                                <a asp-controller="Assignment"
                                       asp-action="DeleteAssignment"
                                       asp-route-id="@item.AssignmentId"
                                       class="btn-delete">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="no-data">
                            No employees assigned
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>