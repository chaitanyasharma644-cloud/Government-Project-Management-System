@model IEnumerable<GPMS.Models.Task>

<link rel="stylesheet" href="~/css/site.css" />

@{
    var taskPermissions = ViewBag.TaskPermissions as Dictionary<int, List<string>>;
    var selectedProjectId = ViewBag.SelectedProjectId?.ToString() ?? "";
    var selectedModuleId = ViewBag.SelectedModuleId?.ToString() ?? "";
    var searchText = ViewBag.Search?.ToString() ?? "";
}

<div class="page-container">

    <div class="page-header">
        <h2 class="page-title">TASKS</h2>
        <a asp-action="Create" class="btn">+ New Task</a>
    </div>

    <form method="get" asp-action="Index" id="filterForm">
        <div class="search-bar">

            <select id="projectId" name="projectId" class="form-control">
                <option value="">All Projects</option>
                @foreach (var p in ViewBag.Projects)
                {
                    if (selectedProjectId == p.Value)
                    {
                        <option value="@p.Value" selected>@p.Text</option>
                    }
                    else
                    {
                        <option value="@p.Value">@p.Text</option>
                    }
                }
            </select>

            <select id="moduleId" name="moduleId" class="form-control">
                <option value="">All Modules</option>
                @foreach (var m in ViewBag.Modules)
                {
                    if (selectedModuleId == m.Value)
                    {
                        <option value="@m.Value" selected>@m.Text</option>
                    }
                    else
                    {
                        <option value="@m.Value">@m.Text</option>
                    }
                }
            </select>

            <input type="text"
                   id="taskSearch"
                   name="search"
                   class="form-control"
                   placeholder="Search task..."
                   value="@searchText" />

        </div>
    </form>

    <div class="card">
        <table class="task-table">
            <thead>
                <tr>
                    <th>Task Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="no-data">No tasks found</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        var perms = taskPermissions != null && taskPermissions.ContainsKey(item.TaskId)
                        ? taskPermissions[item.TaskId]
                        : new List<string>();

                        bool canView = perms.Contains("ViewTask");
                        bool canEdit = perms.Contains("EditTask");
                        bool canDelete = perms.Contains("DeleteTask");

                        var statusClass = string.IsNullOrEmpty(item.TaskStatus)
                        ? ""
                        : item.TaskStatus.ToLower();

                        <tr>
                            <td class="task-name">@item.TaskName</td>
                            <td>@item.TaskDescription</td>

                            <td>
                                <span class="status @statusClass">
                                    @(item.TaskStatus ?? "N/A")
                                </span>
                            </td>

                            <td>@(item.TaskStartDate?.ToString("dd MMM yyyy") ?? "-")</td>
                            <td>@(item.TaskEndDate?.ToString("dd MMM yyyy") ?? "-")</td>

                            <td>
                                <div class="card-actions">
                                    @if (canView)
                                    {
                                        <a asp-action="Details" asp-route-id="@item.TaskId" class="btn">View</a>
                                    }

                                    @if (canEdit)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.TaskId" class="btn">Edit</a>
                                    }

                                    @if (canDelete)
                                    {
                                        <form asp-action="Delete"
                                              asp-route-id="@item.TaskId"
                                              method="post"
                                              style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-delete">Delete</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

</div>

<script>
    const projectDropdown = document.getElementById("projectId");
    const moduleDropdown = document.getElementById("moduleId");
    const searchInput = document.getElementById("taskSearch");
    const filterForm = document.getElementById("filterForm");

    let searchTimeout;

    function submitFilters() {
        filterForm.submit();
    }

    projectDropdown.addEventListener("change", function () {
        const projectId = this.value;

        moduleDropdown.innerHTML = '<option value="">All Modules</option>';

        if (!projectId) {
            submitFilters();
            return;
        }

        fetch(`/Task/GetModulesByProject?projectId=${projectId}`)
            .then(response => response.json())
            .then(data => {
                data.forEach(module => {
                    const option = document.createElement("option");
                    option.value = module.moduleId;
                    option.text = module.moduleName;
                    moduleDropdown.appendChild(option);
                });

                moduleDropdown.value = "";
                submitFilters();
            })
            .catch(error => {
                console.error("Error loading modules:", error);
                submitFilters();
            });
    });

    moduleDropdown.addEventListener("change", function () {
        submitFilters();
    });

    searchInput.addEventListener("keyup", function () {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(function () {
            submitFilters();
        }, 400);
    });
</script>