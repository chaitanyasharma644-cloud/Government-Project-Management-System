@model IEnumerable<GPMS.Models.Task>

<link rel="stylesheet" href="~/css/site.css" />

@{
    var taskPermissions = ViewBag.TaskPermissions as Dictionary<int, List<string>>;
}

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">
        <h2 class="page-title">TASKS</h2>
        <a asp-action="Create" class="btn">+ New Task</a>
    </div>

    <!-- FILTER BAR -->
    <div class="search-bar">

        <select id="projectId" class="form-control">
            <option value="">All Projects</option>
            @foreach (var p in ViewBag.Projects)
            {
                if (Context.Request.Query["projectId"] == p.Value)
                {
                    <option value="@p.Value" selected>@p.Text</option>
                }
                else
                {
                    <option value="@p.Value">@p.Text</option>
                }
            }
        </select>

        <select id="moduleId" class="form-control">
            <option value="">All Modules</option>
            @foreach (var m in ViewBag.Modules)
            {
                if (Context.Request.Query["moduleId"] == m.Value)
                {
                    <option value="@m.Value" selected>@m.Text</option>
                }
                else
                {
                    <option value="@m.Value">@m.Text</option>
                }
            }
        </select>

        <input type="text" id="taskSearch" class="form-control" placeholder="Search task..." />

        
    </div>

    <!-- TABLE -->
    <div class="card">

        <table class="task-table">
            <thead>
                <tr>
                    <th>Task Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="no-data">No tasks found</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        var perms = taskPermissions != null && taskPermissions.ContainsKey(item.TaskId)
                            ? taskPermissions[item.TaskId]
                            : new List<string>();

                        bool canView = perms.Contains("ViewTask");
                        bool canEdit = perms.Contains("EditTask");
                        bool canDelete = perms.Contains("DeleteTask");

                        var statusClass = string.IsNullOrEmpty(item.TaskStatus)
                            ? ""
                            : item.TaskStatus.ToLower();

                        <tr data-project="@item.Module.ProjectId" data-module="@item.ModuleId">
                            <td class="task-name">@item.TaskName</td>
                            <td>@item.TaskDescription</td>

                            <td>
                                <span class="status @statusClass">
                                    @(item.TaskStatus ?? "N/A")
                                </span>
                            </td>

                            <td>@(item.TaskStartDate?.ToString("dd MMM yyyy") ?? "-")</td>
                            <td>@(item.TaskEndDate?.ToString("dd MMM yyyy") ?? "-")</td>

                            <td>
                                <div class="card-actions">

                                    @if (canView)
                                    {
                                        <a asp-action="Details" asp-route-id="@item.TaskId" class="btn">View</a>
                                    }

                                    @if (canEdit)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.TaskId" class="btn">Edit</a>
                                    }

                                    @if (canDelete)
                                    {
                                        <form asp-action="Delete"
                                              asp-route-id="@item.TaskId"
                                              method="post"
                                              style="display:inline;">

                                            <button type="submit" class="btn btn-delete">Delete</button>
                                        </form>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

    </div>

</div>

<script>

    function filterTasks() {

        let search = document.getElementById("taskSearch").value.toLowerCase();
        let project = document.getElementById("projectId").value;
        let module = document.getElementById("moduleId").value;

        let rows = document.querySelectorAll(".task-table tbody tr");

        rows.forEach(row => {

            let name = row.querySelector(".task-name").innerText.toLowerCase();
            let rowProject = row.getAttribute("data-project");
            let rowModule = row.getAttribute("data-module");

            let matchSearch = name.includes(search);
            let matchProject = !project || rowProject === project;
            let matchModule = !module || rowModule === module;

            row.style.display = (matchSearch && matchProject && matchModule) ? "" : "none";

        });
    }

    // live events
    document.getElementById("taskSearch").addEventListener("keyup", filterTasks);
    document.getElementById("projectId").addEventListener("change", filterTasks);
    document.getElementById("moduleId").addEventListener("change", filterTasks);

</script>