@model GPMS.Models.Module

<link rel="stylesheet" href="~/css/project.css" />

<div class="module-page">
    <div class="module-edit-card">

        <h2 class="page-title">Create Module</h2>

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <!-- PROJECT -->
            <div class="form-group">
                <label>Select Project</label>
                <select asp-for="ProjectId"
                        asp-items="ViewBag.ProjectList"
                        class="form-control">
                    <option value="">-- Select Project --</option>
                </select>
                <span asp-validation-for="ProjectId" class="text-danger"></span>
            </div>

            <!-- NAME -->
            <div class="form-group">
                <label>Module Name</label>
                <input asp-for="ModuleName" class="form-control" />
                <span asp-validation-for="ModuleName" class="text-danger"></span>
            </div>

            <!-- DETAILS -->
            <div class="form-group">
                <label>Details</label>
                <textarea asp-for="Details" class="form-control"></textarea>
            </div>

            <!-- STATUS -->
            <div class="form-group">
                <label>Status</label>
                <select asp-for="ModuleStatus" class="form-control">
                    <option value="">-- Select --</option>
                    <option>Ongoing</option>
                    <option>Completed</option>
                </select>
            </div>

            <!-- START DATE -->
            <div class="form-group">
                <label>Start Date</label>
                <input asp-for="ModuleStartDate" type="date" class="form-control" />
            </div>

            <!-- END DATE -->
            <div class="form-group">
                <label>End Date</label>
                <input asp-for="ModuleEndDate" type="date" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">
                Create Module
            </button>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}