@model GPMS.Models.Module

@{
    ViewData["Title"] = "Create Module";
}

<div class="page-container">

    <div class="form-card">

        <h2 class="page-title">Create Module</h2>

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <!-- SELECT PROJECT -->
            <div class="form-group">
                <label>Select Project</label>
                <select id="projectDropdown"
                        asp-for="ProjectId"
                        asp-items="ViewBag.ProjectList"
                        class="form-control">
                    <option value="">-- Select Project --</option>
                </select>
                <span asp-validation-for="ProjectId" class="text-danger"></span>
            </div>

            <!-- MODULE NAME -->
            <div class="form-group">
                <label>Module Name</label>
                <input asp-for="ModuleName"
                       class="form-control"
                       placeholder="Enter task name..." />
                <span asp-validation-for="ModuleName" class="text-danger"></span>
            </div>

            <!-- DESCRIPTION -->
            <div class="form-group">
                <label>Description</label>
                <textarea asp-for="Details"
                          class="form-control"
                          placeholder="Enter module details..."></textarea>
                <span asp-validation-for="Details" class="text-danger"></span>
            </div>

            <!-- STATUS -->
            <div class="form-group">
                <label>Status</label>
                <select asp-for="ModuleStatus" class="form-control">
                    <option value="">-- Select --</option>
                    <option>Ongoing</option>
                    <option>Completed</option>
                </select>
                <span asp-validation-for="ModuleStatus" class="text-danger"></span>
            </div>

            <!-- DATES -->
            <div class="form-row">

                <div class="form-group">
                    <label>Start Date</label>
                    <input asp-for="ModuleStartDate"
                           type="date"
                           class="form-control" />
                    <span asp-validation-for="ModuleStartDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>End Date</label>
                    <input asp-for="ModuleEndDate"
                           type="date"
                           class="form-control" />
                    <span asp-validation-for="ModuleEndDate" class="text-danger"></span>
                </div>

            </div>

            <!-- BUTTON -->
            <button type="submit" class="btn-save">
                Create Module
            </button>

        </form>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const projectDropdown = document.getElementById("projectDropdown");

            if (!projectDropdown) return;

            projectDropdown.addEventListener("change", function () {

                const projectId = this.value;

                if (!projectId) {
                    console.log("No project selected");
                    return;
                }

                console.log("Selected Project ID:", projectId);

                // 👉 Do whatever you want here
                // Example:
                // window.location.href = "/Project/Details/" + projectId;

            });

        });
    </script>
}