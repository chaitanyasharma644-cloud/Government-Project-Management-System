@model IEnumerable<Module>

@{
    ViewData["Title"] = "Modules";

    var canCreate = ViewBag.CanCreateModule ?? false;
    var modulePermissions = ViewBag.ModulePermissions as Dictionary<int, List<string>>;
}

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">
        <h2 class="page-title">MODULES</h2>

        @if (canCreate)
        {
            <a href="/Module/Create" class="btn">+ New Module</a>
        }
    </div>

    <!-- 🔥 FILTER / SEARCH (UPDATED) -->
    <div class="search-bar module-search-bar">

        <select class="form-control" id="projectFilter">
            <option value="">All Projects</option>

            @foreach (var p in ViewBag.Projects)
            {
                <option value="@p.ProjectId">@p.ProjectName</option>
            }
        </select>

        <input type="text"
               id="moduleSearch"
               class="form-control"
               placeholder="Search modules..." />

        <!-- ✅ NEW DATE FILTERS -->
        <input type="date" id="startDate" class="form-control" />
        <input type="date" id="endDate" class="form-control" />

        <!-- ✅ STATUS FILTER -->
        <select id="status" class="form-control">
            <option value="">All Status</option>
            <option value="Ongoing">Ongoing</option>
            <option value="Completed">Completed</option>
        </select>

        <button class="btn btn-primary-custom" onclick="filterModules()">Search</button>

        <!-- ✅ EXPORT BUTTON -->
        <button class="btn btn-success" onclick="exportExcel()">Export</button>

    </div>

    <!-- MODULE GRID -->
    <div class="cards-grid">

        @foreach (var m in Model)
        {
            var perms = modulePermissions != null && modulePermissions.ContainsKey(m.ModuleId)
                ? modulePermissions[m.ModuleId]
                : new List<string>();

            bool canView = perms.Contains("ViewModule");
            bool canEdit = perms.Contains("EditModule");
            bool canDelete = perms.Contains("DeleteModule");

            <div class="card module"
                 data-project="@m.ProjectId"
                 data-start="@m.ModuleStartDate?.ToString("yyyy-MM-dd")"
                 data-end="@m.ModuleEndDate?.ToString("yyyy-MM-dd")">

                <div class="card-content">

                    <div class="card-top">
                        <h3 class="module-name">@m.ModuleName</h3>

                        <span class="status @(m.ModuleStatus == "Completed" ? "completed" : "ongoing")">
                            @(m.ModuleStatus ?? "—")
                        </span>
                    </div>

                </div>

                <div class="card-meta">
                    <span>🎯 @m.Tasks.Count tasks</span>
                    <span>📅 @m.ModuleStartDate?.ToString("MMM dd, yyyy")</span>
                    <span>🏁 @(m.ModuleEndDate?.ToString("MMM dd, yyyy") ?? "N/A")</span>
                </div>

                <hr />

                <div>

                    @if (canView)
                    {
                        <a href="/Module/Details/@m.ModuleId" class="btn">View</a>
                    }

                    @if (canEdit)
                    {
                        <a href="/Module/Edit/@m.ModuleId" class="btn">Edit</a>
                    }

                    @if (canDelete)
                    {
                        <form method="post"
                              action="/Module/Delete/@m.ModuleId"
                              style="display:inline;"
                              onsubmit="return confirm('Delete this module?');">

                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-delete">Delete</button>

                        </form>
                    }

                </div>

            </div>
        }

    </div>

</div>

<script>

    function filterModules() {

        let searchInput = document.getElementById("moduleSearch").value.toLowerCase();
        let projectId = document.getElementById("projectFilter").value;
        let start = document.getElementById("startDate").value;
        let end = document.getElementById("endDate").value;
        let status = document.getElementById("status").value.toLowerCase();

        let cards = document.querySelectorAll(".card.module");

        cards.forEach(card => {

            let name = card.querySelector(".module-name").innerText.toLowerCase();
            let moduleStatus = card.querySelector(".status").innerText.toLowerCase();

            let cardProjectId = card.getAttribute("data-project");
            let startDate = card.getAttribute("data-start");
            let endDate = card.getAttribute("data-end");

            let match = true;

            // 🔍 SEARCH
            if (searchInput && !name.includes(searchInput))
                match = false;

            // 📁 PROJECT
            if (projectId && cardProjectId !== projectId)
                match = false;

            // 📌 STATUS
            if (status && moduleStatus !== status)
                match = false;

            // 📅 START DATE
            if (start && startDate && startDate < start)
                match = false;

            // 📅 END DATE
            if (end && endDate && endDate > end)
                match = false;

            card.style.display = match ? "block" : "none";
        });
    }

    function exportExcel() {
        let start = document.getElementById("startDate").value;
        let end = document.getElementById("endDate").value;
        let status = document.getElementById("status").value;

        window.location.href = `/Module/ExportToExcel?startDate=${start}&endDate=${end}&status=${status}`;
    }

    document.getElementById("moduleSearch").addEventListener("keyup", filterModules);
    document.getElementById("projectFilter").addEventListener("change", filterModules);

</script>