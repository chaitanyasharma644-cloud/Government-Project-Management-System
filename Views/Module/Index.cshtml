@model IEnumerable<Module>

@{
    ViewData["Title"] = "Modules";

    var canCreate = ViewBag.CanCreateModule ?? false;
    var modulePermissions = ViewBag.ModulePermissions as Dictionary<int, List<string>>;
}

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">
        <h2 class="page-title">MODULES</h2>

        @if (canCreate)
        {
            <a href="/Module/Create" class="btn">+ New Module</a>
        }
    </div>

    <!-- FILTER / SEARCH -->
    <div class="search-bar module-search-bar">

        <select class="form-control" id="projectFilter">
            <option value="">All Projects</option>

            @foreach (var p in ViewBag.Projects)
            {
                <option value="@p.ProjectId">@p.ProjectName</option>
            }
        </select>

        <input type="text"
               id="moduleSearch"
               class="form-control"
               placeholder="Search modules..." />

        <button class="btn btn-primary-custom" onclick="searchModules()">Search</button>

    </div>

    <!-- MODULE GRID -->
    <div class="cards-grid">

        @foreach (var m in Model)
        {
            var perms = modulePermissions != null && modulePermissions.ContainsKey(m.ModuleId)
                ? modulePermissions[m.ModuleId]
                : new List<string>();

            bool canView = perms.Contains("ViewModule");
            bool canEdit = perms.Contains("EditModule");
            bool canDelete = perms.Contains("DeleteModule");

            <div class="card module" data-project="@m.ProjectId">
                <div class="card-content">

                    <!-- TOP -->
                    <div class="card-top">
                        <h3 class="module-name">@m.ModuleName</h3>

                        <span class="status @(m.ModuleStatus == "Completed" ? "completed" : "ongoing")">
                            @(m.ModuleStatus ?? "—")
                        </span>
                    </div>

                </div>

                <!-- META -->
                <div class="card-meta">
                    <span>🎯 @m.Tasks.Count tasks</span>
                    <span>📅 @m.ModuleStartDate?.ToString("MMM dd, yyyy")</span>
                    <span>🏁 @(m.ModuleEndDate?.ToString("MMM dd, yyyy") ?? "N/A")</span>
                </div>

                <hr />

                <!-- ACTIONS -->
                <div>

                    @if (canView)
                    {
                        <a href="/Module/Details/@m.ModuleId" class="btn">View</a>
                    }

                    @if (canEdit)
                    {
                        <a href="/Module/Edit/@m.ModuleId" class="btn">Edit</a>
                    }

                    @if (canDelete)
                    {
                        <form method="post"
                              action="/Module/Delete/@m.ModuleId"
                              style="display:inline;"
                              onsubmit="return confirm('Delete this module?');">

                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-delete">Delete</button>

                        </form>
                    }

                </div>

            </div>
        }

    </div>

</div>

<script>

    function filterModules() {

        let searchInput = document.getElementById("moduleSearch").value.toLowerCase();
        let projectId = document.getElementById("projectFilter").value;

        let cards = document.querySelectorAll(".card.module");

        cards.forEach(card => {

            let name = card.querySelector(".module-name").innerText.toLowerCase();

            // ⚠️ you need projectId stored in card (we'll fix below)
            let cardProjectId = card.getAttribute("data-project");

            let matchSearch = name.includes(searchInput);
            let matchProject = !projectId || cardProjectId === projectId;

            if (matchSearch && matchProject) {
                card.style.display = "block";
            } else {
                card.style.display = "none";
            }

        });
    }

    // 🔥 LIVE SEARCH
    document.getElementById("moduleSearch").addEventListener("keyup", filterModules);

    // 🔥 PROJECT FILTER CHANGE
    document.getElementById("projectFilter").addEventListener("change", filterModules);

</script>