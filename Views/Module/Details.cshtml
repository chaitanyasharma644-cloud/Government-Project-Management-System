@model GPMS.Models.Module

@{
    ViewData["Title"] = "Module Details";
}

<div class="page-container">

    <!-- HEADER -->
    <div class="page-header">

        <h2>@Model.ModuleName</h2>

        <span class="status @(Model.ModuleStatus == "Completed" ? "completed" : "ongoing")">
            @(Model.ModuleStatus ?? "—")
        </span>

    </div>

    <!-- MODULE INFO -->
    <p><strong>Project:</strong> @Model.Project?.ProjectName</p>

    <p>@Model.Details</p>

    <div class="card-meta">
        <span>📅 Start: @Model.ModuleStartDate?.ToString("MMM dd, yyyy")</span>
        <span>🏁 @(Model.ModuleEndDate?.ToString("MMM dd, yyyy") ?? "N/A")</span>
    </div>

    <hr />

    <!-- TASK HEADER -->
    <div class="page-header">

        <h3>Tasks</h3>

        <a href="/Task/Create?moduleId=@Model.ModuleId" class="btn">
            + Add Task
        </a>

    </div>

    <!-- TASK GRID -->
    <div class="cards-grid">

        @if (Model.Tasks != null && Model.Tasks.Any())
        {
            foreach (var t in Model.Tasks)
            {
                <div class="card">

                    <!-- TOP -->
                    <div class="card-top">

                        <h4>@t.TaskName</h4>

                        <span class="status @(t.TaskStatus == "Completed" ? "completed" : "ongoing")">
                            @(t.TaskStatus ?? "—")
                        </span>

                    </div>

                    <!-- META -->
                    <div class="card-meta">
                        <span>📅 @t.TaskStartDate?.ToString("MMM dd, yyyy")</span>
                        <span>🏁 @(t.TaskEndDate?.ToString("MMM dd, yyyy") ?? "N/A")</span>
                    </div>

                    <hr />

                    <!-- ACTIONS -->
                    <div>

                        <a href="/Task/Details/@t.TaskId" class="btn">View</a>

                        <a href="/Task/Edit/@t.TaskId" class="btn">Edit</a>

                        <form method="post"
                              action="/Task/Delete/@t.TaskId"
                              style="display:inline;"
                              onsubmit="return confirm('Delete this task?');">

                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-delete">
                                Delete
                            </button>

                        </form>

                    </div>

                </div>
            }
        }
        else
        {
            <p style="text-align:center;">No tasks found</p>
        }

    </div>

</div>