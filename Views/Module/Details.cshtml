@model GPMS.Models.Module
@using System.Linq

<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

@{
    var canCreateTask = ViewBag.CanCreateTask == true;
    var taskPermissions = ViewBag.TaskPermissions as Dictionary<int, List<string>>;
}

<div class="page-container">

    <!-- 🔥 ALERTS -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- MODULE HEADER -->
    <div class="page-header">
        <div>
            <h2 class="page-title">@Model.ModuleName</h2>
            <p class="text-muted">@Model.Details</p>
        </div>

        @if (canCreateTask)
        {
            <a asp-controller="Task"
                   asp-action="Create"
                   asp-route-moduleId="@Model.ModuleId"
                   class="btn">
                + Add Task
            </a>
        }
    </div>

    <!-- MODULE INFO -->
    <div class="card" style="margin-bottom:20px;">
        <p><strong>Project:</strong> @Model.Project?.ProjectName</p>
        <p><strong>Start Date:</strong> @Model.ModuleStartDate?.ToString("dd MMM yyyy")</p>
        <p><strong>End Date:</strong> @Model.ModuleEndDate?.ToString("dd MMM yyyy")</p>
    </div>

    <!-- TASK TABLE -->
    <div class="card">

        <table class="task-table">
            <thead>
                <tr>
                    <th>Task Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Start Date</th>
                    <th>End Date</th>

                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Tasks == null || !Model.Tasks.Any())
                {
                    <tr>
                        <td colspan="6" class="no-data">
                            No tasks found for this module
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.Tasks)
                    {
                        var perms = taskPermissions != null && taskPermissions.ContainsKey(item.TaskId)
                            ? taskPermissions[item.TaskId]
                            : new List<string>();

                        bool canViewTask = perms.Contains("ViewTask");
                        bool canEditTask = perms.Contains("EditTask");
                        bool canDeleteTask = perms.Contains("DeleteTask");

                        var statusClass = string.IsNullOrEmpty(item.TaskStatus)
                            ? ""
                            : item.TaskStatus.ToLower();

                        <tr>
                            <td>@item.TaskName</td>

                            <td>
                                @(string.IsNullOrEmpty(item.TaskDescription)
                                    ? "-"
                                    : item.TaskDescription)
                            </td>

                            <td>
                                <span class="status @statusClass">
                                    @(item.TaskStatus ?? "N/A")
                                </span>
                            </td>

                            <td>@(item.TaskStartDate?.ToString("dd MMM yyyy") ?? "-")</td>
                            <td>@(item.TaskEndDate?.ToString("dd MMM yyyy") ?? "-")</td>

                            <td>
                                <div class="card-actions">

                                    @if (canViewTask)
                                    {
                                        <a asp-controller="Task"
                                               asp-action="Details"
                                               asp-route-id="@item.TaskId"
                                               class="btn">
                                            View
                                        </a>
                                    }

                                    @if (canEditTask)
                                    {
                                        <a asp-controller="Task"
                                               asp-action="Edit"
                                               asp-route-id="@item.TaskId"
                                               class="btn">
                                            Edit
                                        </a>
                                    }

                                    @if (canDeleteTask)
                                    {
                                        <form asp-controller="Task"
                                              asp-action="Delete"
                                              asp-route-id="@item.TaskId"
                                              method="post"
                                              style="display:inline;"
                                              onsubmit="return confirm('Delete task? This will remove all assignments first.')">

                                            @Html.AntiForgeryToken()

                                            <button type="submit" class="btn btn-delete">
                                                Delete
                                            </button>
                                        </form>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

    </div>

    <!-- ============================= -->
    <!-- ASSIGNED EMPLOYEES -->
    <!-- ============================= -->
    @if (ViewBag.CanViewEmployee == true)
    {
        <div class="assignment-container">

            <div class="assignment-header">
                <h3>Assigned Employees</h3>

                @if (ViewBag.CanEditEmployee == true)
                {
                    <a asp-controller="Assignment"
                           asp-action="AssignEmployee"
                           asp-route-id="@Model.ModuleId"
                           asp-route-type="module"
                           class="btn">
                        + Add Assignment
                    </a>
                }
            </div>

            <table class="assignment-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Email</th>
                        <th>Username</th>
                        <th>Assigned Date</th>

                        @if (ViewBag.CanEditEmployee == true)
                        {
                            <th>Actions</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Assignments != null && Model.Assignments.Any())
                    {
                        foreach (var item in Model.Assignments)
                        {
                            <tr>
                                <td>@item.Employee.EmployeeName</td>
                                <td>@(item.Role != null ? item.Role.RoleName : "Not assigned")</td>
                                <td>@item.Employee.Email</td>
                                <td>@item.Employee.Username</td>
                                <td>@item.AssignedDate.ToString("dd MMM yyyy")</td>

                                @if (ViewBag.CanEditEmployee == true)
                                {
                                    <td class="action-buttons">
                                        <a asp-controller="Assignment"
                                               asp-action="DeleteAssignment"
                                               asp-route-id="@item.AssignmentId"
                                               class="btn btn-delete">
                                            Remove
                                        </a>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="no-data">
                                No employees assigned
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    }

</div>