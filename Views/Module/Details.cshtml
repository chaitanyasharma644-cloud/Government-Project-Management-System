@model GPMS.Models.Module
@using System.Linq

<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

<div class="page-container">

    <!-- MODULE HEADER -->
    <div class="page-header">
        <div>
            <h2 class="page-title">@Model.ModuleName</h2>
            <p class="text-muted">@Model.Details</p>
        </div>

        <a asp-controller="Task"
               asp-action="Create"
               asp-route-moduleId="@Model.ModuleId"
               class="btn">
            + Add Task
        </a>
    </div>

    <!-- MODULE INFO -->
    <div class="card" style="margin-bottom:20px;">
        <p><strong>Project:</strong> @Model.Project?.ProjectName</p>
        <p><strong>Start Date:</strong> @Model.ModuleStartDate?.ToString("dd MMM yyyy")</p>
        <p><strong>End Date:</strong> @Model.ModuleEndDate?.ToString("dd MMM yyyy")</p>
    </div>

    <!-- TASK TABLE -->
    <div class="card">

        <table class="task-table">
            <thead>
                <tr>
                    <th>Task Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Tasks == null || !Model.Tasks.Any())
                {
                    <tr>
                        <td colspan="6" class="no-data">
                            No tasks found for this module
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.Tasks)
                    {
                        var statusClass = string.IsNullOrEmpty(item.TaskStatus)
                            ? ""
                            : item.TaskStatus.ToLower();

                        <tr>
                            <td>@item.TaskName</td>

                            <td>
                                @(string.IsNullOrEmpty(item.TaskDescription)
                                    ? "-"
                                    : item.TaskDescription)
                            </td>

                            <!-- STATUS -->
                            <td>
                                <span class="status @statusClass">
                                    @(item.TaskStatus ?? "N/A")
                                </span>
                            </td>

                            <!-- START DATE -->
                            <td>
                                @(item.TaskStartDate?.ToString("dd MMM yyyy") ?? "-")
                            </td>

                            <!-- END DATE -->
                            <td>
                                @(item.TaskEndDate?.ToString("dd MMM yyyy") ?? "-")
                            </td>

                            <!-- ACTIONS -->
                            <td>
                                <div class="card-actions">

                                    <a asp-controller="Task"
                                           asp-action="Details"
                                           asp-route-id="@item.TaskId"
                                           class="btn">
                                        View
                                    </a>

                                    <a asp-controller="Task"
                                           asp-action="Edit"
                                           asp-route-id="@item.TaskId"
                                           class="btn">
                                        Edit
                                    </a>

                                    <form asp-controller="Task"
                                          asp-action="Delete"
                                          asp-route-id="@item.TaskId"
                                          method="post"
                                          style="display:inline;">
                                        <button type="submit" class="btn btn-delete">
                                            Delete
                                        </button>
                                    </form>

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

    </div>

    <!-- ============================= -->
    <!-- ASSIGNED EMPLOYEES SECTION -->
    <!-- ============================= -->

    <div class="assignment-container">

        <div class="assignment-header">
            <h3>Assigned Employees</h3>

            <a asp-controller="Assignment"
                   asp-action="AssignEmployee"
                   asp-route-id="@Model.ModuleId"
                   asp-route-type="module"
                   class="btn">
                + Add Assignment
            </a>
        </div>

        <table class="assignment-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Role</th>
                    <th>Email</th>
                    <th>Username</th>
                    <th>Assigned Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Assignments != null && Model.Assignments.Any())
                {
                    foreach (var item in Model.Assignments)
                    {
                        <tr>
                            <td>@item.Employee.EmployeeName</td>
                            <td>@item.Role?.RoleName Not assigned</td>
                            <td>@item.Employee.Email</td>
                            <td>@item.Employee.Username</td>
                            <td>@item.AssignedDate.ToString("dd MMM yyyy")</td>

                            <td class="action-buttons">
                                <a asp-controller="Assignment"
                                       asp-action="DeleteAssignment"
                                       asp-route-id="@item.AssignmentId"
                                       class="btn btn-delete">
                                    Remove
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="no-data">
                            No employees assigned
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>