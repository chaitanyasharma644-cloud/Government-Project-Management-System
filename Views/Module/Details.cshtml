@model GPMS.Models.Module

<link rel="stylesheet" href="/css/modules.css" />

<div class="module-details-page">


    <!-- MODULE HEADER -->
    <div class="module-header">

        <h1>@Model.ModuleName</h1>

        <!-- PROJECT NAME -->
        <div class="module-project">
            Project: <strong>@Model.Project.ProjectName</strong>
        </div>

        <div class="module-meta">

            <span class="status-badge">
                @Model.ModuleStatus
            </span>

            <span class="date">
                📅 @Model.ModuleStartDate?.ToString("dd-MM-yyyy")
                -
                @Model.ModuleEndDate?.ToString("dd-MM-yyyy")
            </span>

        </div>

    </div>


    <!-- MODULE DESCRIPTION -->
    <div class="module-description">
        @Model.Details
    </div>


    <!-- TASK SECTION -->
    <div class="tasks-header">

        <h2 class="tasks-title">
            Tasks (@Model.Tasks.Count)
        </h2>

        <a href="/Task/Create?moduleId=@Model.ModuleId"
           class="btn-add-task">
            + Add Task
        </a>

    </div>


    <!-- TASK TABLE -->
    <div class="tasks-table-wrapper">

        <table class="tasks-table">

            <thead>
                <tr>
                    <th>Task</th>
                    <th>Status</th>
                    <th>Start</th>
                    <th>End</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Tasks != null && Model.Tasks.Any())
                {
                    foreach (var task in Model.Tasks)
                    {
                        <tr>

                            <td class="task-name">
                                @task.TaskName
                            </td>

                            <td>
                                <span class="task-status">
                                    @task.TaskStatus
                                </span>
                            </td>

                            <td>
                                @task.TaskStartDate
                            </td>

                            <td>
                                @task.TaskEndDate
                            </td>

                            <td class="task-actions">

                                <a href="/Task/Details/@task.TaskId"
                                   class="btn-action view">
                                    View
                                </a>

                                <a href="/Task/Edit/@task.TaskId"
                                   class="btn-action edit">
                                    Edit
                                </a>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="no-tasks">
                            No tasks available for this module.
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
