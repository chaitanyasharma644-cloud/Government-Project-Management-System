@model IEnumerable<GPMS.Models.Designation>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between mb-3">
        <h3>DESIGNATIONS</h3>
        <a asp-action="Create" class="btn btn-primary">+ New Designation</a>
    </div>

    <!-- SEARCH -->
    <form method="get" class="row mb-4">
        <div class="col-md-8">
            <input name="search" class="form-control form-control-lg"
                   placeholder="Search designation..."
                   value="@Context.Request.Query["search"]" />
        </div>

        <div class="col-md-2">
            <button class="btn btn-primary w-100">Search</button>
        </div>
    </form>

    <!-- CARD TABLE -->
    <div class="card shadow-sm p-3">
        <div class="card-body">

            <table class="table table-hover w-100">
                <thead class="custom-header">
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <!-- MAIN ROW -->
                        <tr>
                            <td>@item.DesignationName</td>
                            <td>@item.DesignationDescription</td>
                            <td>
                                <!-- VIEW -->
                                <a asp-action="Details" asp-route-id="@item.DesignationId"
                                   class="btn btn-info btn-sm">View</a>

                                <!-- EDIT -->
                                <button class="btn btn-warning btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editModal_@item.DesignationId">
                                    Edit
                                </button>

                                <!-- DELETE -->
                                <button class="btn btn-danger btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal_@item.DesignationId">
                                    Delete
                                </button>
                            </td>
                        </tr>

                        <!-- ✅ DELETE MODAL -->
                        <div class="modal fade" id="deleteModal_@item.DesignationId" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">

                                    <div class="modal-header bg-danger text-white">
                                        <h5>Confirm Delete</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>

                                    <div class="modal-body">
                                        <p>Are you sure you want to delete this designation?</p>
                                        <strong>@item.DesignationName</strong>
                                    </div>

                                    <div class="modal-footer">
                                        <form asp-action="Delete" method="post">
                                            <input type="hidden" name="id" value="@item.DesignationId" />
                                            <button type="submit" class="btn btn-danger">Yes, Delete</button>
                                        </form>

                                        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <!-- ✅ EDIT MODAL -->
                        <div class="modal fade" id="editModal_@item.DesignationId" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">

                                    <form asp-action="Edit" method="post">

                                        <div class="modal-header">
                                            <h5>Edit Designation</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>

                                        <div class="modal-body">

                                            <input type="hidden" name="DesignationId" value="@item.DesignationId" />

                                            <div class="mb-3">
                                                <label>Name</label>
                                                <input name="DesignationName"
                                                       class="form-control"
                                                       value="@item.DesignationName" required />
                                            </div>

                                            <div class="mb-3">
                                                <label>Description</label>
                                                <input name="Description"
                                                       class="form-control"
                                                       value="@item.DesignationDescription" />
                                            </div>

                                        </div>

                                        <div class="modal-footer">
                                            <button type="submit" class="btn btn-primary">Update</button>
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                        </div>

                                    </form>

                                </div>
                            </div>
                        </div>
                    }
                </tbody>
