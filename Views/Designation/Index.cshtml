@model IEnumerable<GPMS.Models.Designation>

@{
    ViewData["Title"] = "Designations";
}

<link rel="stylesheet" href="~/css/site.css" />

<style>
    :root {
        --primary: #ef4444;
    }

    /* SEARCH */
    .search-bar {
        margin-bottom: 15px;
    }

        .search-bar input {
            width: 1075px;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 6px;
        }

    /* TABLE */
    .designation-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 10px;
        overflow: hidden;
    }

        .designation-table thead {
            background-color: var(--primary);
            color: white;
        }

        .designation-table th {
            padding: 14px;
            text-align: left;
            font-weight: 500;
        }

        .designation-table td {
            padding: 14px;
        }

        .designation-table tbody tr {
            border-bottom: 1px solid #eee;
            transition: 0.2s;
        }

            .designation-table tbody tr:hover {
                background-color: #fff5f5;
            }

    .actions a {
        margin-right: 6px;
    }

    .no-data {
        text-align: center;
        padding: 20px;
        color: #888;
    }

    /* ✅ ALERT STYLES (added) */
    .alert-success {
        background: #dcfce7;
        color: #166534;
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 10px;
    }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 10px;
    }
</style>

<div class="page-container">

    <!-- ✅ ALERT MESSAGES (added) -->
    @if (TempData["Success"] != null)
    {
        <div class="alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert-error">
            @TempData["Error"]
        </div>
    }

    <!-- HEADER -->
    <div class="page-header">
        <h2 class="page-title">DESIGNATIONS</h2>
        <a asp-action="Create" class="btn">+ Add Designation</a>
    </div>

    <!-- 🔥 LIVE SEARCH -->
    <div class="search-bar">
        <input type="text" id="designationSearch" placeholder="Search designation..." />
    </div>

    <!-- TABLE -->
    <table class="designation-table">
        <thead>
            <tr>
                <th>Designation Name</th>
                <th>Description</th>
                <th style="width:120px;">Actions</th>
            </tr>
        </thead>

        <tbody id="designationTableBody">
            @if (Model != null && Model.Any())
            {
                foreach (var des in Model)
                {
                    <tr>
                        <td class="des-name">@des.DesignationName</td>
                        <td>@des.DesignationDescription</td>

                        <td class="actions">
                            <form asp-action="Delete" asp-route-id="@des.DesignationId" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-delete"
                                        onclick="return confirm('Are you sure you want to delete this designation?')">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="no-data">No designations found</td>
                </tr>
            }
        </tbody>
    </table>

</div>

<!-- 🔥 LIVE SEARCH SCRIPT -->
<script>
    function filterDesignations() {
        let input = document.getElementById("designationSearch").value.toLowerCase();
        let rows = document.querySelectorAll("#designationTableBody tr");

        rows.forEach(row => {
            let nameCell = row.querySelector(".des-name");
            if (!nameCell) return;

            let name = nameCell.innerText.toLowerCase();
            row.style.display = name.includes(input) ? "" : "none";
        });
    }

    document.getElementById("designationSearch").addEventListener("keyup", filterDesignations);
</script>